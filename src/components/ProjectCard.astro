---
interface Props {
  title: string;
  description: string;
  color: 'sky' | 'coral' | 'sun' | 'leaf';
  icon: 'heart' | 'book' | 'gift' | 'hands';
}
const { title, description, color, icon } = Astro.props;

const bg: Record<string, string> = {
  sky: 'bg-sky/10',
  coral: 'bg-coral/10',
  sun: 'bg-sun/15',
  leaf: 'bg-leaf/10',
};
const ring: Record<string, string> = {
  sky: 'bg-sky',
  coral: 'bg-coral',
  sun: 'bg-sun',
  leaf: 'bg-leaf',
};

const icons: Record<string, string> = {
  heart: 'M12 21s-7.5-4.9-10-9.4C.4 8 2 4.5 5.6 4c2-.3 3.9.6 5 2.2C11.7 4.6 13.6 3.7 15.6 4c3.6.5 5.2 4 3.6 7.6C21.5 16.1 12 21 12 21z',
  book: 'M4 5.5C4 4.7 4.7 4 5.5 4H11v16H5.5A1.5 1.5 0 0 1 4 18.5v-13zM20 5.5c0-.8-.7-1.5-1.5-1.5H13v16h5.5a1.5 1.5 0 0 0 1.5-1.5v-13z',
  gift: 'M20 12v9H4v-9M2 7h20v5H2V7zm10 0V3.5A2.5 2.5 0 1 0 9.5 6l2.5 1zm0 0V3.5A2.5 2.5 0 1 1 14.5 6L12 7zM12 7v14',
  hands: 'M8 12l3 3 6-6M4 20h16a1 1 0 0 0 1-1V9a1 1 0 0 0-1-1H4a1 1 0 0 0-1 1v10a1 1 0 0 0 1 1z',
};
---
<div class={`group relative rounded-3xl ${bg[color]} p-7 md:p-8 flex flex-col gap-4 transition-transform duration-200 hover:-translate-y-1.5`}>
  <span class={`h-14 w-14 rounded-2xl ${ring[color]} text-white flex items-center justify-center shadow-soft`}>
    <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d={icons[icon]} />
    </svg>
  </span>
  <h3 class="font-display font-bold text-xl text-ink">{title}</h3>
  <p class="text-ink/70 leading-relaxed text-[15px]">{description}</p>
  <slot />
</div>
