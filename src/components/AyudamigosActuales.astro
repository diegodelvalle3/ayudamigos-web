---
import Layout from "../layouts/Layout.astro";
import PageHero from "../components/PageHero.astro";
import WaveDivider from "../components/WaveDivider.astro";
import empleada from "../images/ayudamigos/ayudamigo_iyari.png";

import { miembros } from "../data/miembros";

// Mapeo de rol
const estiloPorRol = {
    Fundador: {
        borde: "border-sky",
        badge: "bg-sky",
        texto: "text-sky-dark",
    },
    Voluntario: {
        borde: "border-sun",
        badge: "bg-sun",
        texto: "text-sun-dark",
    },
    Voluntaria: {
        borde: "border-sun",
        badge: "bg-sun",
        texto: "text-sun-dark",
    },
    Digital: {
        borde: "border-coral",
        badge: "bg-coral",
        texto: "text-coral-dark",
    },
};
const estiloDefault = {
    borde: "border-leaf",
    badge: "bg-leaf",
    texto: "text-leaf-dark",
};

// Precalculamos el estilo de cada miembro ANTES del template,
// así el .map() de abajo queda simple, igual que en el resto del sitio.
const miembrosConEstilo = miembros.map((m) => ({
    ...m,
    estilo: estiloPorRol[m.rol] ?? estiloDefault,
}));
---

<section class="mx-auto max-w-7xl px-5 md:px-8 py-16 md:py-20">
    <div
        class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-8"
    >
        {
            miembrosConEstilo.map((m) => (
                <div class="group rounded-3xl bg-white shadow-soft overflow-hidden relative transition-transform duration-200 hover:-translate-y-1.5">
                    <div class="relative">
                        <img
                            src={m.img_url.src}
                            alt={m.nombre}
                            class="w-full h-[320px] object-cover"
                        />
                        <span
                            class={`absolute top-3 right-3 rounded-full ${m.estilo.badge} text-white text-xs font-display font-bold px-3 py-1 shadow-soft`}
                        >
                            {m.rol}
                        </span>
                    </div>

                    <div class={`p-5 border-t-4 ${m.estilo.borde}`}>
                        <p class="font-display font-bold text-lg text-ink leading-tight">
                            {m.nombre}
                        </p>
                        <p class="text-ink/60 text-sm mt-0.5">
                            Ayudamigo(a) desde {m.miembro_desde}
                        </p>

                        {/* <a
                            href={`https://${m.instagram}`}
                            target="_blank"
                            rel="noopener noreferrer"
                            class={`mt-3 inline-flex items-center gap-1.5 text-sm font-display font-semibold ${m.estilo.texto} hover:gap-2.5 transition-all`}
                        >
                            <svg
                                width="16"
                                height="16"
                                viewBox="0 0 24 24"
                                fill="currentColor"
                            >
                                <path d="M12 2.2c2.7 0 3 0 4 .1 1 .05 1.7.2 2.3.5.6.2 1.1.6 1.6 1.1.5.5.8 1 1.1 1.6.2.6.4 1.3.5 2.3 0 1 .1 1.3.1 4s0 3-.1 4c-.05 1-.2 1.7-.5 2.3-.2.6-.6 1.1-1.1 1.6-.5.5-1 .8-1.6 1.1-.6.2-1.3.4-2.3.5-1 0-1.3.1-4 .1s-3 0-4-.1c-1-.05-1.7-.2-2.3-.5-.6-.2-1.1-.6-1.6-1.1-.5-.5-.8-1-1.1-1.6-.2-.6-.4-1.3-.5-2.3 0-1-.1-1.3-.1-4s0-3 .1-4c.05-1 .2-1.7.5-2.3.2-.6.6-1.1 1.1-1.6.5-.5 1-.8 1.6-1.1.6-.2 1.3-.4 2.3-.5 1 0 1.3-.1 4-.1zM12 7a5 5 0 1 0 0 10 5 5 0 0 0 0-10zm0 8.2a3.2 3.2 0 1 1 0-6.4 3.2 3.2 0 0 1 0 6.4zm5.2-8.4a1.2 1.2 0 1 1-2.4 0 1.2 1.2 0 0 1 2.4 0z" />
