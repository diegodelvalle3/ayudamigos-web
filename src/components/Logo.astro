---
interface Props {
  light?: boolean;
  class?: string;
}
const { light = false, class: klass = "" } = Astro.props;
const textColor = light ? "text-white" : "text-ink";

import logo from "../images/ayudamigosLogo.png";
---

<a href="/" class={`flex items-center gap-2.5 group ${klass}`}>
  <img src={logo.src} alt="Ayudamigos Logo" class="header_logo" />
  <span
    class={`font-display font-extrabold text-xl leading-tight ${textColor}`}
  >
    Ayudamigos<span
      class="block text-xs font-body font-semibold tracking-wide -mt-0.5 opacity-80"
      >Juventud al Cambio</span
    >
  </span>
</a>

<style>
  .header_logo {
    width: 50px;
  }
</style>
