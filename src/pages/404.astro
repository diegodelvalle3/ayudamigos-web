---
import Layout from '../layouts/Layout.astro';
import Blob from '../components/Blob.astro';
---
<Layout title="Página no encontrada">
  <section class="relative overflow-hidden bg-sky min-h-[70vh] flex items-center">
    <Blob color="#FFC845" class="absolute -top-16 -left-16 w-72 h-72 opacity-70" />
    <Blob color="#4CB963" class="absolute -bottom-20 -right-10 w-80 h-80 opacity-60" />
    <div class="relative mx-auto max-w-2xl px-5 md:px-8 py-24 text-center">
      <p class="font-display font-extrabold text-7xl md:text-8xl text-white">404</p>
      <h1 class="mt-4 font-display font-extrabold text-2xl md:text-3xl text-white">
        Este amigo se perdió en el camino
      </h1>
      <p class="mt-4 text-white/90 leading-relaxed">
        La página que buscas no existe o cambió de lugar. Volvamos juntos al inicio.
      </p>
      <a href="/" class="btn-secondary mt-8 inline-flex">Volver al inicio</a>
    </div>
  </section>
</Layout>
