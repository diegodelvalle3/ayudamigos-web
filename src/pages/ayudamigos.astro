---
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/PageHero.astro';
import WaveDivider from '../components/WaveDivider.astro';

const equipo = [
  { name: 'Coordinación general', role: 'Dirección de proyectos', color: 'bg-coral' },
  { name: 'Relaciones comunitarias', role: 'Vínculo con familias y donantes', color: 'bg-sky' },
  { name: 'Rifamigos', role: 'Organización de rifas solidarias', color: 'bg-sun' },
  { name: 'Redes sociales', role: 'Comunicación y difusión', color: 'bg-leaf' },
  { name: 'Logística', role: 'Entregas y jornadas comunitarias', color: 'bg-coral' },
  { name: 'Nuevos ayudamigos', role: '¡Este espacio podría ser tuyo!', color: 'bg-sky' },
];
---
<Layout title="Ayudamigos" description="Conoce al equipo de voluntarios que forma parte de Ayudamigos, Juventud al Cambio.">
  <PageHero
    color="coral"
    eyebrow="Nuestro equipo"
    title="Los ayudamigos detrás del cambio"
    description="Un grupo de jóvenes voluntarios que dedica su tiempo a construir una mejor comunidad."
  />

  <WaveDivider from="#FF6F59" to="#FFFBF0" />

  <section class="mx-auto max-w-7xl px-5 md:px-8 py-16 md:py-20">
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {equipo.map((m) => (
        <div class="rounded-3xl bg-white shadow-soft p-7 flex items-center gap-4">
          <span class={`h-14 w-14 rounded-2xl ${m.color} shrink-0`}></span>
          <div>
            <h3 class="font-display font-bold text-lg text-ink">{m.name}</h3>
            <p class="text-ink/60 text-sm">{m.role}</p>
          </div>
        </div>
      ))}
    </div>

    <div class="mt-16 rounded-[2rem] bg-sky text-white p-8 md:p-12 text-center">
      <h2 class="font-display font-extrabold text-2xl md:text-3xl">¿Quieres ser parte del equipo?</h2>
      <p class="mt-3 text-white/90 max-w-xl mx-auto leading-relaxed">
        Siempre estamos buscando nuevos ayudamigos con ganas de aportar tiempo, ideas y energía a la comunidad.
      </p>
      <a href="/ser-ayudamigo" class="btn-secondary mt-6">Quiero ser ayudamigo</a>
    </div>
  </section>
</Layout>
